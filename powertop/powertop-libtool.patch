Replace obsolete AC_PROG_LIBTOOL with LT_INIT for autoconf 2.72+.

Without this, autoconf 2.72 errors with "undefined or overquoted macro" for
all macros following AC_PROG_LIBTOOL.

diff --git a/configure.ac b/configure.ac
--- a/configure.ac
+++ b/configure.ac
@@ -34,7 +34,7 @@
 # Checks for programs.
 AC_PROG_CPP
 AC_PROG_CXX
-AC_PROG_LIBTOOL
+LT_INIT
 AC_PROG_CC
 AC_PROG_INSTALL
 AM_PROG_CC_C_O
