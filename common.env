export NODE_OPTIONS="--max-old-space-size=512"
export NEXT_JS_WORKER_THREADS=1

export GOFLAGS=""
export GOTOOLCHAIN=local

# Use a reproducible hash seed when compiling Python bytecode
export PYTHONHASHSEED=0

# Supply-chain hardening: block npm/pypi attacks (sha1-hulud, packagegate, etc.)
# - npm install scripts can run arbitrary code; disable them.
# - Pin npm-internal git/shell to system tools so a hijacked package can't override them.
# - Don't let `uv` silently download external Python builds.
export npm_config_ignore_scripts='true'
export npm_config_git='/usr/bin/git'
export npm_config_shell='/bin/sh'
export npm_config_script_shell='/bin/sh'
export UV_PYTHON_DOWNLOADS=never
