{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":automergeAll",
    ":disableRateLimiting",
  ],
  "commitMessageTopic": "{{depName}}",
  "commitMessageExtra": "to {{newVersion}}",
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": ["/.+\\.ya?ml$/"],
      "matchStringsStrategy": "combination",
      "matchStrings": [
        "version:\\s*['\"]?\(?<currentValue>(\\d+\\.)+\\d+\)['\"]?",
        "repository:\\s*https:\\/\\/github\\.com\\/(?<depName>[^\\n]+)"
      ],
      "datasourceTemplate": "github-tags",
      "versioningTemplate": "loose",
      "extractVersionTemplate": "^v?(?<version>(\\d+\\.)+\\d+)$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/.+\\.ya?ml$/"],
      "matchStringsStrategy": "combination",
      "matchStrings": [
        "version:\\s*['\"]?\(?<currentValue>(\\d+\\.)+\\d+\)['\"]?",
        "repository:\\s*https:\\/\\/github\\.com\\/(?<depName>[^\\n]+)\\n#\\s*datasource:\\s*github-releases"
      ],
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "loose",
      "extractVersionTemplate": "^v?(?<version>(\\d+\\.)+\\d+)$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/.+\\.ya?ml$/"],
      "matchStringsStrategy": "combination",
      "matchStrings": [
        "version:\\s*['\"]?\(?<currentValue>(\\d+\\.)+\\d+\)['\"]?",
        "repository:\\s*https:\\/\\/codeberg\\.org\\/(?<depName>.*)"
      ],
      "registryUrlTemplate": "https://codeberg.org",
      "datasourceTemplate": "forgejo-tags",
      "versioningTemplate": "loose",
      "extractVersionTemplate": "^v?(?<version>(\\d+\\.)+\\d+)$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/.+\\.ya?ml$/"],
      "matchStringsStrategy": "combination",
      "matchStrings": [
        "version:\\s*['\"]?\(?<currentValue>(\\d+\\.)+\\d+\)['\"]?",
        "repository:\\s*https:\\/\\/gitlab\\.freedesktop\\.org\\/(?<depName>.*)"
      ],
      "registryUrlTemplate": "https://gitlab.freedesktop.org",
      "datasourceTemplate": "gitlab-tags",
      "versioningTemplate": "loose",
      "extractVersionTemplate": "^v?(?<version>(\\d+\\.)+\\d+)$"
    },
    {
      // Bump pinned `go-1.X` toolchain references via the wolfi apk index.
      "customType": "regex",
      "managerFilePatterns": ["/.+\\.ya?ml$/"],
      "matchStrings": [
        "\\bgo-(?<currentValue>1\\.\\d+)(?:[^\\d.]|$)"
      ],
      "depNameTemplate": "go",
      "datasourceTemplate": "custom.wolfi-base",
      "versioningTemplate": "loose"
    }
  ],
  "customDatasources": {
    "wolfi-base": {
      "defaultRegistryUrlTemplate": "http://apk-wolfi:3000/{{packageName}}"
    }
  },
  "packageRules": [
    {
      // Reset epoch to 0 only on upstream version bumps.
      "matchDatasources": ["github-tags","gitlab-tags","forgejo-tags","github-releases"],
      "groupName": "tags",
      "postUpgradeTasks": {
        "commands": [
          "sed -i -E 's/^([[:space:]]*epoch:)[[:space:]]+[0-9]+.*$/\\1 0/' '{{{packageFile}}}'",
        ],
        "fileFilters": ["**/*.yaml", "**/*.yml"],
        "executionMode": "update",
      },
    },
    {
      // Packages that repackage GitHub Release assets (not bare git tags) have
      // "# datasource: github-releases" and are handled by the github-releases
      // manager. Disable the github-tags manager for them to avoid duplicate MRs.
      // Add new packages here if they also use "# datasource: github-releases".
      "matchManagers": ["custom.regex"],
      "matchDatasources": ["github-tags"],
      "matchPackageNames": [
        "intel/intel-graphics-compiler",
        "intel/compute-runtime"
      ],
      "enabled": false
    },
    {
      // Trim apk version to major.minor so PRs fire only on new minors.
      "matchDatasources": ["custom.wolfi-base"],
      "matchPackageNames": ["go"],
      "extractVersion": "^([0-9]+\\.[0-9]+)",
      "groupName": "go-toolchain"
    }
  ]
}
