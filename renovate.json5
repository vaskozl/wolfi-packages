{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":automergeAll",
    ":disableRateLimiting",
  ],
  "commitMessageTopic": "{{depName}}",
  "commitMessageExtra": "to {{newVersion}}",
  "customManagers": [
    {
      // GitHub package tracker — fires on any yaml with a
      // `# repository: https://github.com/owner/repo` annotation.
      // Defaults to the github-tags datasource. To override to github-releases
      // (e.g. for packages that repackage release binaries rather than source
      // tags), add a `# datasource: github-releases` comment on the line
      // immediately above `# repository:`.
      "customType": "regex",
      "managerFilePatterns": ["/.+\\.ya?ml$/"],
      "matchStringsStrategy": "combination",
      "matchStrings": [
        "version:\\s*['\"]?(?<currentValue>\\d+(?:\\.\\d+)*)['\"]?",
        "(?:#\\s*datasource:\\s*(?<datasource>github-\\S+)\\s*\\n\\s*)?#\\s*repository:\\s*https:\\/\\/github\\.com\\/(?<depName>[^\\n]+)"
      ],
      "datasourceTemplate": "{{#if datasource}}{{datasource}}{{else}}github-tags{{/if}}",
      "versioningTemplate": "loose",
      "extractVersionTemplate": "^v?(?<version>\\d+(?:\\.\\d+)*)$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/.+\\.ya?ml$/"],
      "matchStringsStrategy": "combination",
      "matchStrings": [
        "version:\\s*['\"]?\(?<currentValue>(\\d+\\.)+\\d+\)['\"]?",
        "repository:\\s*https:\\/\\/codeberg\\.org\\/(?<depName>.*)"
      ],
      "registryUrlTemplate": "https://codeberg.org",
      "datasourceTemplate": "forgejo-tags",
      "versioningTemplate": "loose",
      "extractVersionTemplate": "^v?(?<version>(\\d+\\.)+\\d+)$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/.+\\.ya?ml$/"],
      "matchStringsStrategy": "combination",
      "matchStrings": [
        "version:\\s*['\"]?\(?<currentValue>(\\d+\\.)+\\d+\)['\"]?",
        "repository:\\s*https:\\/\\/gitlab\\.freedesktop\\.org\\/(?<depName>.*)"
      ],
      "registryUrlTemplate": "https://gitlab.freedesktop.org",
      "datasourceTemplate": "gitlab-tags",
      "versioningTemplate": "loose",
      "extractVersionTemplate": "^v?(?<version>(\\d+\\.)+\\d+)$"
    },
    {
      // Track `# repository: https://git.kernel.org/...` annotations via
      // the git-tags datasource (no API; renovate clones to list tags).
      "customType": "regex",
      "managerFilePatterns": ["/.+\\.ya?ml$/"],
      "matchStringsStrategy": "combination",
      "matchStrings": [
        "version:\\s*['\"]?(?<currentValue>\\d+(?:\\.\\d+)*)['\"]?",
        "#\\s*repository:\\s*(?<packageName>https:\\/\\/git\\.kernel\\.org\\/\\S+)"
      ],
      "depNameTemplate": "{{packageName}}",
      "datasourceTemplate": "git-tags",
      "versioningTemplate": "loose",
      "extractVersionTemplate": "^v?(?<version>\\d+(?:\\.\\d+)*)$"
    },
    {
      // Bump pinned `go-1.X` toolchain references via the wolfi apk index.
      "customType": "regex",
      "managerFilePatterns": ["/.+\\.ya?ml$/"],
      "matchStrings": [
        "\\bgo-(?<currentValue>1\\.\\d+)(?:[^\\d.]|$)"
      ],
      "depNameTemplate": "go",
      "datasourceTemplate": "custom.wolfi-base",
      "versioningTemplate": "loose"
    },
    {
      // Generic apk-datasource manager. Annotate the line above `version:`:
      //   # datasource: <name> packageName: <apk>
      // where <name> is a key in customDatasources (e.g. alpine-base,
      // wolfi-base). Avoids having one regex manager per datasource.
      "customType": "regex",
      "managerFilePatterns": ["/.+\\.ya?ml$/"],
      "matchStrings": [
        "#\\s*datasource:\\s*(?<datasource>[\\w-]+)\\s+packageName:\\s*(?<depName>\\S+)\\s*\\n\\s*version:\\s*['\"]?(?<currentValue>\\d+(?:\\.\\d+)*)['\"]?"
      ],
      "datasourceTemplate": "custom.{{datasource}}",
      "versioningTemplate": "loose"
    }
  ],
  "customDatasources": {
    "wolfi-base": {
      "defaultRegistryUrlTemplate": "http://apk-wolfi:3000/{{packageName}}"
    },
    "alpine-base": {
      "defaultRegistryUrlTemplate": "http://apk-alpine:3000/{{packageName}}"
    }
  },
  "packageRules": [
    {
      // On an upstream version bump: reset the bumped yaml's epoch to 0
      // and bump epoch on every reverse-dep so CI rebuilds them against
      // the new apk. --base-ref HEAD because renovate hasn't committed yet
      // -- bump-epochs diffs working tree vs HEAD to find renovate's edits.
      // Resulting yaml changes are picked up via fileFilters: **/*.yaml.
      "matchDatasources": ["github-tags","github-releases","gitlab-tags","forgejo-tags","git-tags","custom.alpine-base"],
      "postUpgradeTasks": {
        "commands": [
          ".gitlab/bump-epochs.pl --base-ref HEAD",
        ],
        "fileFilters": ["**/*.yaml", "**/*.yml"],
        "executionMode": "update",
      },
    },
    {
      // Trim apk version to major.minor so PRs fire only on new minors.
      "matchDatasources": ["custom.wolfi-base"],
      "matchPackageNames": ["go"],
      "extractVersion": "^([0-9]+\\.[0-9]+)",
      "groupName": "go-toolchain"
    },
    {
      // Strip the Alpine `-rN` suffix so the version written into the YAML
      // matches melange's `version` field (epoch lives separately).
      "matchDatasources": ["custom.alpine-base"],
      "extractVersion": "^(?<version>\\d+(?:\\.\\d+)*)"
    },
    {
      // Pin SPIRV-LLVM-Translator to the LLVM 19 release line so it
      // stays ABI-compatible with Wolfi's llvm-19 and mesa-full's llvm-ver: 19.
      "matchDatasources": ["github-tags"],
      "matchPackageNames": ["KhronosGroup/SPIRV-LLVM-Translator"],
      "allowedVersions": "/^19\\./"
    },
    {
      // SPIRV-Tools uses date-based tags (vYYYY.N). Track only stable date
      // releases: exclude the legacy vulkan-sdk-* tags and the .rc prereleases.
      "matchDatasources": ["github-tags"],
      "matchPackageNames": ["KhronosGroup/SPIRV-Tools"],
      "versioning": "loose",
      "allowedVersions": "/^[0-9]{4}\\.[0-9]+$/"
    },
    {
      // Track libclc against Wolfi's llvm-19 apk (its ABI peer); strip the
      // apk -rN suffix and cap to the 19.x line so it stays matched to
      // mesa-full's llvm-ver: 19 and the spirv-llvm-translator.
      "matchDatasources": ["custom.wolfi-base"],
      "matchPackageNames": ["llvm-19"],
      "extractVersion": "^(?<version>\\d+(?:\\.\\d+)*)",
      "allowedVersions": "/^19\\./"
    }
  ]
}
